# ============================================================================
# Production config for docker-compose.prod.yml.
#   1. Copy this file to .env.prod   (cp .env.prod.example .env.prod)
#   2. Fill in real values below.
#   3. NEVER commit .env.prod — it is gitignored.
# ============================================================================

# Your domain (apex, no scheme). The app is served at https://${DOMAIN}, the API
# at https://api.${DOMAIN}. Point DNS A records for @ , www and api at this VPS.
DOMAIN=example.com

# ---- Database (MySQL) — use long random passwords ----
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password
MYSQL_DATABASE=jmaa
MYSQL_USER=jmaa
MYSQL_PASSWORD=CHANGE_ME_strong_db_password

# ---- JWT secrets — generate each with:  openssl rand -hex 32 ----
JWT_ACCESS_SECRET=CHANGE_ME_64_hex_chars
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_hex_chars

# ---- First admin account (seeded on boot; promotes/creates this user as ADMIN) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ---- Email (Resend) ----
# Needed for password-reset / verification / notification emails. Leave the key
# as re_xxx to log emails to the container console instead of sending them.
# MAIL_FROM must use a domain you've verified in Resend.
RESEND_API_KEY=re_xxx
MAIL_FROM=Jmaa <noreply@example.com>

# ---- Optional: Google OAuth (leave blank to disable the Google login button) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Optional: Cloudflare Turnstile CAPTCHA on signup (leave blank to disable) ----
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Payments (Paddle) ----
# Intentionally omitted for the soft launch → dev-simulation, no real charges.
# When you're ready to charge real money, see the "Going live with payments"
# section in DEPLOY.md and add the PADDLE_* vars (here + in compose) plus the
# VITE_PADDLE_CLIENT_TOKEN baked into the web build.
