# Point the frontend at the live hudlgo backend. Leave blank to use the built-in
# in-memory mock (fully offline demo).
VITE_API_URL=http://localhost:4000

# Payments run through Paddle. The frontend opens Paddle.js overlay checkout, so
# set the client-side token here (server keys live in server/.env as PADDLE_*).
# Leave the token blank to fall back to the backend dev-simulation (no overlay).
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_ENV=sandbox

# Cloudflare Turnstile site key (CAPTCHA on signup). Leave blank to disable the
# widget; the backend bypasses verification when its secret is unset too.
VITE_TURNSTILE_SITE_KEY=
