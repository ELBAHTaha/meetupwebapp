# ---- Core ----
NODE_ENV=development
PORT=4000
# Origin of the Vite frontend (CORS)
FRONTEND_URL=http://localhost:5173

# ---- Database (MySQL 8) ----
# When using docker-compose, host is "mysql"; locally it's "localhost".
DATABASE_URL="mysql://jmaa:jmaa@localhost:3306/jmaa"

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

# ---- Google OAuth (optional — leave blank to disable) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ---- Storage (local disk for now) ----
STORAGE_DRIVER=local
UPLOADS_DIR=uploads
# Public base used to build absolute photo URLs
PUBLIC_URL=http://localhost:4000

# ---- Throttler ----
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=usd

# Host subscription plans (create in Stripe dashboard → Products)
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_PREMIUM_PRICE_ID=price_xxx

# Attendee premium (optional upsell)
STRIPE_ATTENDEE_PREMIUM_PRICE_ID=price_xxx

# Business venue sponsorships
STRIPE_BRONZE_PRICE_ID=price_xxx
STRIPE_SILVER_PRICE_ID=price_xxx
STRIPE_GOLD_PRICE_ID=price_xxx
