# ---- Core ----
NODE_ENV=development
PORT=4000
# Origin of the Vite frontend (CORS)
FRONTEND_URL=http://localhost:5173

# ---- Database (MySQL 8) ----
# When using docker-compose, host is "mysql"; locally it's "localhost".
DATABASE_URL="mysql://jmaa:jmaa@localhost:3306/jmaa"

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

# ---- Google OAuth (optional — leave blank to disable) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ---- Storage (local disk for now) ----
STORAGE_DRIVER=local
UPLOADS_DIR=uploads
# Public base used to build absolute photo URLs
PUBLIC_URL=http://localhost:4000

# ---- Throttler ----
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# ---- Email (Resend) ----
# Leave the API key as "xxx" to log emails to the console instead of sending (dev
# simulation). Paste a real key (re_...) to send. MAIL_FROM must use a domain
# verified in Resend (onboarding@resend.dev works for testing to your own inbox).
RESEND_API_KEY=re_xxx
MAIL_FROM="hudlgo <onboarding@resend.dev>"

# ---- Payments: Paddle (Billing) ----
# Global kill switch. Payments stay BLOCKED unless this is exactly "true"
# (server refuses every checkout, incl. the dev-simulation auto-grant). Keep it
# off until the Paddle account is approved and live price ids are set below.
# The client UI has a matching flag: VITE_PAYMENTS_ENABLED (see frontend env).
PAYMENTS_ENABLED=false
# Leave PADDLE_API_KEY blank (or with "xxx") to use the dev simulation (no real
# charge). Set environment to "production" for the live Paddle account.
PADDLE_API_KEY=
PADDLE_ENVIRONMENT=sandbox
# Notification-setting signing secret used to verify webhook payloads.
PADDLE_WEBHOOK_SECRET=
# Catalog price ids (create the products/prices in the Paddle dashboard).
PADDLE_HOST_PRO_PRICE_ID=
PADDLE_EXTRA_PRIORITY_PRICE_ID=
# Business sponsorships — one recurring price id per tier × billing term.
PADDLE_BIZ_STARTER_MONTHLY_PRICE_ID=
PADDLE_BIZ_STARTER_QUARTERLY_PRICE_ID=
PADDLE_BIZ_STARTER_ANNUAL_PRICE_ID=
PADDLE_BIZ_BRONZE_MONTHLY_PRICE_ID=
PADDLE_BIZ_BRONZE_QUARTERLY_PRICE_ID=
PADDLE_BIZ_BRONZE_ANNUAL_PRICE_ID=
PADDLE_BIZ_SILVER_MONTHLY_PRICE_ID=
PADDLE_BIZ_SILVER_QUARTERLY_PRICE_ID=
PADDLE_BIZ_SILVER_ANNUAL_PRICE_ID=

# ---- Frontend (Vite) ----
# Client-side payments kill switch — must be exactly "true" to show purchase
# buttons. Mirror it to PAYMENTS_ENABLED above. Off → the UI shows "coming soon"
# and the server refuses checkout anyway.
VITE_PAYMENTS_ENABLED=false
# Paddle.js overlay token (client-side, pri_…/live or test). Only needed once
# payments are enabled.
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_ENV=sandbox
