# ---- Core ----
NODE_ENV=development
PORT=4000
# Origin of the Vite frontend (CORS)
FRONTEND_URL=http://localhost:5173

# ---- Database (MySQL 8) ----
# When using docker-compose, host is "mysql"; locally it's "localhost".
DATABASE_URL="mysql://jmaa:jmaa@localhost:3306/jmaa"

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

# ---- Google OAuth (optional — leave blank to disable) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ---- Storage (local disk for now) ----
STORAGE_DRIVER=local
UPLOADS_DIR=uploads
# Public base used to build absolute photo URLs
PUBLIC_URL=http://localhost:4000

# ---- Throttler ----
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# ---- Paddle ----
# Leave the API key as "xxx" to use the dev simulation (no real charge).
PADDLE_API_KEY=apikey_xxx
PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxx
PADDLE_ENVIRONMENT=sandbox
PADDLE_CURRENCY=usd

# Host membership tiers (create in Paddle dashboard → Catalog → Prices)
PADDLE_HOST_BRONZE_PRICE_ID=pri_xxx
PADDLE_HOST_SILVER_PRICE_ID=pri_xxx
PADDLE_HOST_GOLD_PRICE_ID=pri_xxx

# Business venue sponsorships
PADDLE_BRONZE_PRICE_ID=pri_xxx
PADDLE_SILVER_PRICE_ID=pri_xxx
PADDLE_GOLD_PRICE_ID=pri_xxx

# One-time extra-activity fees ($0.99 express / $2.99 priority)
PADDLE_EXPRESS_PRICE_ID=pri_xxx
PADDLE_PRIORITY_PRICE_ID=pri_xxx

# ---- Email (Resend) ----
# Leave the API key as "xxx" to log emails to the console instead of sending (dev
# simulation). Paste a real key (re_...) to send. MAIL_FROM must use a domain
# verified in Resend (onboarding@resend.dev works for testing to your own inbox).
RESEND_API_KEY=re_xxx
MAIL_FROM="hudlgo <onboarding@resend.dev>"
